# ── データベース（必須） ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/mangamap

# ── CORS 許可オリジン（カンマ区切り） ─────────────────────────────────
# 開発時: http://localhost:5173,http://localhost:3000
# 本番時: https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── プリレンダリング用サイトURL ────────────────────────────────────────
SITE_URL=https://your-domain.com
